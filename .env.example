# ─────────────────────────────────────────────────────────────────────────────
# Application
# ─────────────────────────────────────────────────────────────────────────────
APP_NAME="Real-Time AI Chat Backend"
APP_VERSION="0.1.0"
APP_ENV="development"          # development | testing | production
DEBUG=true

# Comma-separated allowed CORS origins
CORS_ORIGINS='["http://localhost:3000","http://localhost:5173"]'

HOST="0.0.0.0"
PORT=8000

# ─────────────────────────────────────────────────────────────────────────────
# Database (PostgreSQL + asyncpg)
# ─────────────────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql+asyncpg://postgres:postgres@localhost:5432/chatdb"
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800
DB_ECHO=false

# ─────────────────────────────────────────────────────────────────────────────
# Redis
# ─────────────────────────────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379/0"
REDIS_MAX_CONNECTIONS=20

# ─────────────────────────────────────────────────────────────────────────────
# JWT / Authentication
# ─────────────────────────────────────────────────────────────────────────────
# IMPORTANT: generate a strong random value for production, e.g.:
#   python -c "import secrets; print(secrets.token_hex(64))"
JWT_SECRET_KEY="CHANGE_ME_IN_PRODUCTION"
JWT_ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ─────────────────────────────────────────────────────────────────────────────
# Logging
# ─────────────────────────────────────────────────────────────────────────────
LOG_LEVEL="INFO"
LOG_JSON=false   # set to true in production for structured log aggregation
